# 未配置任何密钥时会自动进入 Mock 演示模式。
AI_PROVIDER=mock

# 每类任务可独立指定模型。模型名称不在业务代码中写死。
AI_MODEL_EXPAND=
AI_MODEL_SUMMARY=
AI_MODEL_PLAN=
AI_MODEL_PROMPT=
AI_MODEL_VISION=

# OpenAI
OPENAI_API_KEY=

# Google Gemini
GOOGLE_GENERATIVE_AI_API_KEY=

# DeepSeek（通过 OpenAI-compatible 适配器）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 自定义 OpenAI-compatible / MiMo 等
CUSTOM_AI_BASE_URL=
CUSTOM_AI_API_KEY=
CUSTOM_AI_MODEL=

# 可选服务约束
AI_REQUEST_TIMEOUT_MS=30000
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=24
AI_IDEMPOTENCY_TTL_MS=15000
